```dotenv
# ============================================================
# PostgreSQL
# ============================================================

POSTGRES_DB=finance_db
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=replace-with-a-strong-database-password

# Mac 宿主机访问 PostgreSQL 的端口
POSTGRES_PORT=5433


# ============================================================
# 本地运行 Spring Boot 时使用
# Docker Compose 会将其覆盖为 postgres:5432
# ============================================================

DATABASE_URL=jdbc:postgresql://localhost:5433/finance_db
DATABASE_USERNAME=finance_user
DATABASE_PASSWORD=replace-with-the-same-database-password


# ============================================================
# JWT
# JWT_SECRET 至少需要32字节
# ============================================================

JWT_SECRET=replace-with-a-random-secret-at-least-32-bytes-long
JWT_EXPIRATION_SECONDS=7200


# ============================================================
# Anthropic 兼容模型接口
# ============================================================

ANTHROPIC_BASE_URL=https://moark.com/anthropic
ANTHROPIC_AUTH_TOKEN=replace-with-your-model-api-token

ANTHROPIC_MODEL=DeepSeek-V4-Flash
ANTHROPIC_SMALL_FAST_MODEL=GLM-4.7-Flash

ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_TEMPERATURE=0.2


# ============================================================
# 前后端地址
# ============================================================

FRONTEND_URL=http://localhost:3000

# 该变量会在 Next.js 构建阶段写入浏览器端代码。
# 浏览器访问的是 Mac 的8080端口，不能填写 backend:8080。
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
```
